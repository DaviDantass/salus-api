# ====================================
# Salus API - Environment Variables
# ====================================
# Copy this file to .env and update with your values

# Database Configuration
# =====================
DATASOURCE_URL=jdbc:mysql://localhost:3306/salus_api?useSSL=false&serverTimezone=UTC
DATASOURCE_USERNAME=salus_user
DATASOURCE_PASSWORD=your_secure_password_here

# JWT Security Configuration
# ==========================
# Generate a secure key: openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# Server Configuration (Optional)
# =============================
# SERVER_PORT=8080

# Application Profile (development, production, test)
# ==================================================
# SPRING_PROFILES_ACTIVE=development

# Database Pool Configuration (Optional)
# =====================================
# spring.datasource.hikari.maximum-pool-size=10
# spring.datasource.hikari.minimum-idle=2

# JPA/Hibernate Configuration (Optional)
# ======================================
# spring.jpa.show-sql=false
# spring.jpa.properties.hibernate.format_sql=true

# Logging Configuration (Optional)
# ================================
# logging.level.root=INFO
# logging.level.com.davidantassdev.salus=DEBUG

# ====================================
# MySQL Database Creation Script
# ====================================
# Execute these commands in your MySQL client:
# 
# CREATE DATABASE salus_api;
# CREATE DATABASE salus_api_test;
# 
# CREATE USER 'salus_user'@'localhost' IDENTIFIED BY 'your_secure_password_here';
# GRANT ALL PRIVILEGES ON salus_api.* TO 'salus_user'@'localhost';
# GRANT ALL PRIVILEGES ON salus_api_test.* TO 'salus_user'@'localhost';
# GRANT SUPER ON *.* TO 'salus_user'@'localhost';
# FLUSH PRIVILEGES;
